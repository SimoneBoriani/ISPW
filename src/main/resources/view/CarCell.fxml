<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.geometry.Insets?>

<HBox fx:id="rootAnchor" spacing="15" styleClass="car-card" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
        <ImageView fx:id="imgAuto" fitHeight="120" fitWidth="160" preserveRatio="true" />
        <VBox spacing="5" HBox.hgrow="ALWAYS">
                <Label fx:id="lblModello" styleClass="car-title" text="Marca Modello" />
                <Label fx:id="lblDettagli" styleClass="car-details" text="Km • Anno • Alimentazione" />
                <Label fx:id="lblPrezzo" styleClass="car-price" text="€ 0.00" />
                <Region VBox.vgrow="ALWAYS" />
                <Label fx:id="lblLuogo" styleClass="car-location" text="Italia" />
            <padding>
                <Insets bottom="5.0" top="5.0" />
            </padding>
        </VBox>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
</HBox>